# Порт API для Vite proxy (по умолчанию 5001, см. Makefile)
VITE_API_PORT=5001

# Явные URL (опционально, обходят proxy; нужен CORS на бэкенде)
# VITE_API_URL=http://localhost:5001/api
# VITE_SOCKET_URL=ws://localhost:5001/ws

# Docker
# VITE_API_PORT=5000
# VITE_API_URL=http://localhost:5000/api
# VITE_SOCKET_URL=ws://localhost:5000/ws
